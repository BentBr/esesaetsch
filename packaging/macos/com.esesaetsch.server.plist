<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.esesaetsch.server</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/esesaetsch</string>
        <string>serve</string>
        <string>--config</string>
        <string>/etc/esesaetsch/config.toml</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardErrorPath</key>
    <string>/var/log/esesaetsch.err.log</string>
    <key>StandardOutPath</key>
    <string>/var/log/esesaetsch.out.log</string>
</dict>
</plist>
